 125          //==================== 按键扫描（防抖） ====================
 126          unsigned char KeyScan(void)
 127          {
 128   1              if(KEY1 == 0)
 129   1              {
 130   2                      Delay(20);
 131   2                      if(KEY1 == 0)
 132   2                      {
 133   3                              while(KEY1 == 0);
 134   3                              return 1;
 135   3                      }
 136   2              }
 137   1              if(KEY2 == 0)
 138   1              {
 139   2                      Delay(20);
 140   2                      if(KEY2 == 0)
 141   2                      {
 142   3                              while(KEY2 == 0);
 143   3                              return 2;
 144   3                      }
 145   2              }
 146   1              return 0;
 147   1      }
