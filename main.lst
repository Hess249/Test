 149          //==================== 播放函数 ====================
 150          void PlayMusic(unsigned char code *music)
 151          {
 152   1              TR0 = 0;
 153   1              MusicSelect = 0;
 154   1              
 155   1              while(1)
 156   1              {
 157   2                      if(music[MusicSelect] == 0xFF)
 158   2                      {
 159   3                              TR0 = 0;
 160   3                              break;
 161   3                      }
 162   2                      
 163   2                      FreqSelect = music[MusicSelect];
 164   2                      MusicSelect++;
 165   2                      TR0 = 1;
 166   2                      Delay(SPEED/4 * music[MusicSelect]);
 167   2                      MusicSelect++;
 168   2                      TR0 = 0;
 169   2                      Delay(5);
 170   2              }
 171   1      }
